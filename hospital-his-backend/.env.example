# ══════════════════════════════════════════════════════════════════════════════
# HOSPITAL HIS BACKEND - ENVIRONMENT CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values

# ─────────────────────────────────────────────────────────────────────────────
# SERVER CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5001

# ─────────────────────────────────────────────────────────────────────────────
# MONGODB CONFIGURATION (Primary Database)
# ─────────────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/hospital_his?retryWrites=true&w=majority

# ─────────────────────────────────────────────────────────────────────────────
# REDIS CONFIGURATION (Caching & Sessions)
# ─────────────────────────────────────────────────────────────────────────────
# Set USE_REDIS_CACHE=true to enable Redis
USE_REDIS_CACHE=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# For Redis Cloud / AWS ElastiCache:
# REDIS_HOST=redis-xxxxx.cloud.redislabs.com
# REDIS_PORT=12345
# REDIS_PASSWORD=your_redis_password
# REDIS_TLS=true

# ─────────────────────────────────────────────────────────────────────────────
# POSTGRESQL CONFIGURATION (Billing & Inventory)
# ─────────────────────────────────────────────────────────────────────────────
# Set USE_POSTGRES_BILLING=true and/or USE_POSTGRES_INVENTORY=true to enable
USE_POSTGRES_BILLING=false
USE_POSTGRES_INVENTORY=false
DUAL_WRITE_MODE=true

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=lifeline_his
POSTGRES_USER=lifeline
POSTGRES_PASSWORD=your_secure_password
POSTGRES_SSL=false

# For production / cloud PostgreSQL:
# POSTGRES_HOST=your-instance.region.rds.amazonaws.com
# POSTGRES_SSL=true

# ─────────────────────────────────────────────────────────────────────────────
# JWT AUTHENTICATION
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=1h
JWT_REFRESH_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# ─────────────────────────────────────────────────────────────────────────────
# CORS CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# ─────────────────────────────────────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL CONFIGURATION (SMTP)
# ─────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@hospital.com
FROM_NAME=Hospital HIS

# ─────────────────────────────────────────────────────────────────────────────
# AWS S3 CONFIGURATION (File Storage)
# ─────────────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=hospital-his-uploads

# ─────────────────────────────────────────────────────────────────────────────
# ML SERVICES CONFIGURATION
# ─────────────────────────────────────────────────────────────────────────────
# Nudge ML Service
NUDGE_ML_SERVICE_URL=http://localhost:8000

# Revenue Leakage ML Service
REVENUE_ML_SERVICE_URL=http://localhost:8001

# Predictive Analytics ML Service
PREDICTIVE_ML_SERVICE_URL=http://localhost:8002

# Voice Agent Service
VOICE_AGENT_URL=http://localhost:5005

# AI OCR Service (Handwriting Recognition)
AI_OCR_SERVICE_URL=http://localhost:5006

# ─────────────────────────────────────────────────────────────────────────────
# EXTERNAL INTEGRATIONS
# ─────────────────────────────────────────────────────────────────────────────
# Fitbit
FITBIT_CLIENT_ID=your_fitbit_client_id
FITBIT_CLIENT_SECRET=your_fitbit_client_secret
FITBIT_REDIRECT_URI=http://localhost:5173/devices/callback/fitbit

# Google Fit
GOOGLE_FIT_CLIENT_ID=your_google_client_id
GOOGLE_FIT_CLIENT_SECRET=your_google_client_secret
GOOGLE_FIT_REDIRECT_URI=http://localhost:5173/devices/callback/google-fit

# ─────────────────────────────────────────────────────────────────────────────
# OPENAI CONFIGURATION (for AI features)
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs
